DOMAIN=phc-nexus.eu
STAGING_AUTH_USER=staging
# Bcrypt hash z `caddy hash-password` — všechny $ zdvojit na $$ (Docker Compose interpolace)
STAGING_AUTH_HASH=CHANGE_ME

# =============================================================================
# H6 — Trusted IP whitelist pro staging (obchází Basic Auth)
#
# Space-separated CIDR rozsahy (office, VPN, home office statické IP).
# Default 0.0.0.0 = žádný trusted IP (všichni musí přes Basic Auth).
#
# Příklad pro jednu office + OpenVPN subnet + dva home-office staticky:
#   STAGING_TRUSTED_IPS="203.0.113.0/24 10.8.0.0/24 198.51.100.42/32 198.51.100.43/32"
#
# /up endpoint je vždy public bez ohledu na tuto proměnnou (pro UptimeRobot).
# =============================================================================
STAGING_TRUSTED_IPS=0.0.0.0
