# =============================================================================
# PHC Nexus — Production Environment
# Zkopírovat jako .env na produkčním serveru a vyplnit hodnoty.
# =============================================================================

APP_NAME="PHC Nexus"
APP_ENV=production
APP_KEY=
# ↑ Vygeneruje se: docker compose exec app php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://phc-nexus.eu

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Produkce → stderr (Docker zachytí přes `docker compose logs`, log se
# neztratí při force-recreate kontejneru). Lokální debug může použít
# LOG_STACK=single,stderr pro duplicitní zápis.
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# Sentry error tracking — dsn.sentry.io → Project Settings → Client Keys
# Prázdný DSN = Sentry SDK je no-op (pro dev). V prod vyplnit.
# send_default_pii=false — nikdy neposílat email/IP/cookies (PHI ochrana).
# =============================================================================
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
# Git SHA nastavuje deploy workflow; manuální release lze override.
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
# Traces (performance) vypnuté — free tier vydrží jen errors, PHI risk na bindings.
SENTRY_TRACES_SAMPLE_RATE=

# =============================================================================
# Database — PostgreSQL (silné heslo!)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=phc_nexus
DB_USERNAME=phc_nexus
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
# SSL režim — prefer = šifrovat pokud server podporuje, require = vynutit, verify-full = + ověřit CA
DB_SSLMODE=prefer

# Compose-only — musí být shodné s DB_USERNAME/DB_PASSWORD/DB_DATABASE
POSTGRES_DB=phc_nexus
POSTGRES_USER=phc_nexus
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS

# =============================================================================
# Session — Redis
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=data
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# =============================================================================
# Queue & Cache — Redis
# =============================================================================
QUEUE_CONNECTION=redis
QUEUE_REDIS_CONNECTION=data

CACHE_STORE=redis
CACHE_REDIS_CONNECTION=cache

# =============================================================================
# Redis — cache instance (allkeys-lru)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=CHANGE_ME_REDIS_CACHE_PASSWORD

# =============================================================================
# Redis — data instance (noeviction, sessions + queues)
# =============================================================================
REDIS_DATA_HOST=redis-data
REDIS_DATA_PORT=6379
REDIS_DATA_PASSWORD=CHANGE_ME_REDIS_DATA_PASSWORD

# =============================================================================
# Mail — produkční SMTP (SendGrid, Office 365, vlastní)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="nexus@phc-nexus.eu"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Google SSO — OAuth credentials z Google Cloud Console
# Callback URL: https://phc-nexus.eu/auth/google/callback
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback
# Povolené e-mailové domény pro Google SSO (čárkou oddělené)
AUTH_GOOGLE_ALLOWED_DOMAINS=pearseurope.com,pearshealthcyber.com

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Trusted proxies — Caddy předává X-Forwarded-* headery
# Bez důvěry Request::ip() vrací IP kontejneru → rate limitery throttlují
# globálně, audit log nemá forensics value.
# "*" = důvěra jakékoli proxy (bezpečné, Caddy je jediný vstup).
# =============================================================================
TRUSTED_PROXIES=*

# =============================================================================
# Produkční doména (používá Caddyfile.prod pro auto-TLS)
# =============================================================================
DOMAIN=phc-nexus.eu

# =============================================================================
# Docker image tag z GHCR — nastavuje deploy workflow na sha-<short>.
# Pro rollback: scripts/rollback.sh <sha> production
# =============================================================================
IMAGE_TAG=latest

# =============================================================================
# Backup — GPG-šifrovaný off-site backup do Backblaze B2
# Skripty: scripts/backup.sh (cron 02:00), scripts/restore-drill.sh (kvartálně).
# Detail setup: docs/runbooks/backup-restore.md.
# =============================================================================
BACKUP_DIR=/opt/backups
BACKUP_GPG_RECIPIENT=backup@phc-nexus.eu
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_B2_REMOTE=phc-b2
BACKUP_B2_BUCKET=phc-nexus-backups
# BACKUP_SKIP_UPLOAD=1 — jen lokální (pro test GPG flow bez B2)
BACKUP_SKIP_UPLOAD=0
