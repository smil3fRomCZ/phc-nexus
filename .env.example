APP_NAME="PHC Nexus"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=phc_nexus
DB_USERNAME=phc_nexus
DB_PASSWORD=secret

# Session — Redis (data instance)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=data

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Queue — Redis (data instance)
QUEUE_CONNECTION=redis
QUEUE_REDIS_CONNECTION=data

# Cache — Redis (cache instance)
CACHE_STORE=redis
CACHE_REDIS_CONNECTION=cache

# Redis — cache instance (allkeys-lru)
REDIS_CLIENT=phpredis
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=null

# Redis — data instance (noeviction, sessions + queues)
REDIS_DATA_HOST=redis-data
REDIS_DATA_PORT=6379
REDIS_DATA_PASSWORD=null

# Mail — Mailpit for local dev
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="nexus@pearshealthcare.cz"
MAIL_FROM_NAME="${APP_NAME}"

# Google SSO (fill in your OAuth credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback

VITE_APP_NAME="${APP_NAME}"
