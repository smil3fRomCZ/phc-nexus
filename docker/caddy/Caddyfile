{
	# Local dev — self-signed TLS
	local_certs
}

localhost {
	# Serve static files directly
	root * /var/www/html/public
	file_server

	# Vite dev server proxy (HMR)
	@vite path /@@vite/* /@id/* /@fs/* /node_modules/*
	reverse_proxy @vite app:5173

	# PHP-FPM for everything else
	php_fastcgi app:9000 {
		root /var/www/html/public
	}

	# Compression
	encode gzip zstd

	# Security headers
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
