# =============================================================================
# PHC Nexus — Staging Environment
# Zkopírovat jako .env.staging na VPS (/opt/phc-nexus-staging/) a vyplnit hodnoty.
# =============================================================================

APP_NAME="PHC Nexus [STAGING]"
APP_ENV=staging
APP_KEY=
# ↑ Vygeneruje se: docker compose exec app php artisan key:generate --force
APP_DEBUG=false
APP_URL=https://dev.phc-nexus.eu

APP_LOCALE=cs
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=cs_CZ

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Database — PostgreSQL (staging DB)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=phc_nexus_staging
DB_USERNAME=phc_nexus_staging
DB_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
# SSL mode: prefer = použít TLS pokud server podporuje, jinak plain.
# Pro managed Postgres (FORPSI, cloud) přepnout na `require`.
DB_SSLMODE=prefer

# Compose-only — staging postgres kontejner
REDIS_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD

# =============================================================================
# Session — Redis (data instance, DB 1)
# =============================================================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=data
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# =============================================================================
# Queue & Cache — Redis (jeden kontejner, různé DB indexy)
# =============================================================================
QUEUE_CONNECTION=redis
QUEUE_REDIS_CONNECTION=data

CACHE_STORE=redis
CACHE_REDIS_CONNECTION=cache

# =============================================================================
# Redis — cache (DB 0)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_CACHE_HOST=redis
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_CACHE_DB=0

# =============================================================================
# Redis — data/sessions/queues (DB 1)
# =============================================================================
REDIS_DATA_HOST=redis
REDIS_DATA_PORT=6379
REDIS_DATA_PASSWORD=CHANGE_ME_STAGING_REDIS_PASSWORD
REDIS_DATA_DB=1

# =============================================================================
# Mail — Mailpit (vše zachyceno, nic se neodešle)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="staging@phc-nexus.eu"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Google SSO — OAuth credentials (staging callback URL)
# Callback URL: https://dev.phc-nexus.eu/auth/google/callback
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback
# Povolené e-mailové domény pro Google SSO (čárkou oddělené)
AUTH_GOOGLE_ALLOWED_DOMAINS=pearseurope.com,pearshealthcyber.com

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Staging doména
# =============================================================================
DOMAIN=dev.phc-nexus.eu
